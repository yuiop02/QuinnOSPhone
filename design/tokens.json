    "heading.md": {
      "fontSize": 22,
      "lineHeight": 26,
      "fontWeight": "900",
      "letterSpacing": -0.8
    },
    "title.sm": {
      "fontSize": 17,
      "lineHeight": 22,
      "fontWeight": "800",
      "letterSpacing": -0.4
    },
    "body.md": {
      "fontSize": 15,
      "lineHeight": 22,
      "fontWeight": "600",
      "letterSpacing": 0
    },
    "body.sm": {
      "fontSize": 14,
      "lineHeight": 21,
      "fontWeight": "500",
      "letterSpacing": 0
    },
    "eyebrow": {
      "fontSize": 11,
      "lineHeight": 14,
      "fontWeight": "900",
      "letterSpacing": 1.2
    }
  },
  "spacing": {
    "xs": 6,
    "sm": 10,
    "md": 14,
    "lg": 18,
    "xl": 24,
    "xxl": 32
  },
  "radii": {
    "sm": 12,
    "md": 18,
    "lg": 24,
    "xl": 30,
    "pill": 999
  },
  "stroke": {
    "hairline": 1,
    "rule": 1,
    "accent": 1
  },
  "shadows": {
    "paper": {
      "color": "rgba(17,17,17,0.08)",
      "offsetX": 0,
      "offsetY": 4,
      "blur": 18,
      "spread": 0
