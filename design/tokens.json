{
  "meta": {
    "name": "QuinnOS Sprint 2",
    "theme": "Hero Gravity",
    "version": "2.0.0"
  },
  "colors": {
    "bg.cream": "#F6F0E4",
    "bg.creamSoft": "#FBF7EF",
    "surface.tile": "#F3EADB",
    "surface.tileAlt": "#EEE1CA",
    "ink.primary": "#111111",
    "ink.muted": "#4A463E",
    "accent.gold": "#B88A2A",
    "accent.goldSoft": "rgba(184,138,42,0.16)",
    "rule.gold": "#B88A2A",
    "rule.soft": "#D8C8A6",
    "node.forest": "#1E3C34",
    "node.clay": "#7A4B18",
    "node.berry": "#8B1E2D"
  },
  "type": {
    "display.xl": {
      "fontSize": 34,
      "lineHeight": 38,
      "fontWeight": "900",
      "letterSpacing": -1.1
    },
    "display.lg": {
      "fontSize": 30,
      "lineHeight": 34,
      "fontWeight": "900",
      "letterSpacing": -1
